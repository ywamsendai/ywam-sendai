---
const { lang = "en" } = Astro.props;

const isEnglish = lang === "en";

const copy = {
  en: {
    title: "Ask AI",
    subtitle: "YWAM SENDAI GUIDE",
    close: "Close",
    placeholder: "Ask a question...",
    send: "Send",
    thinking: "Thinking...",
    you: "You",
    guide: "Guide",
    greeting: "Hi, I’m the YWAM Sendai Guide. How can I help?",
    fallback: "I'm sorry, I couldn't find an answer in the guide.",
    connectionError: "Connection error.",
    prompt1: "What is DTS?",
    prompt2: "How do I apply?",
    prompt3: "Life in Sendai",
    prompt4: "How can I contact you?",
    apply: "Apply",
    contact: "Contact",
    handbook: "Handbook"
  },
  ja: {
    title: "AIに相談",
    subtitle: "YWAM仙台ガイド",
    close: "閉じる",
    placeholder: "質問を入力してください...",
    send: "送信",
    thinking: "考えています...",
    you: "あなた",
    guide: "ガイド",
    greeting: "こんにちは。YWAM仙台ガイドです。どのようにお手伝いできますか？",
    fallback: "申し訳ありません。ガイド内で答えが見つかりませんでした。",
    connectionError: "接続エラーが発生しました。",
    prompt1: "DTSとは？",
    prompt2: "申し込み方法",
    prompt3: "仙台での生活",
    prompt4: "連絡方法",
    apply: "申し込み",
    contact: "お問い合わせ",
    handbook: "ハンドブック"
  }
};

const t = isEnglish ? copy.en : copy.ja;

const handbookUrl = isEnglish
  ? "https://guide.ywamsendai.org/en"
  : "https://guide.ywamsendai.org/ja";

const applyUrl = isEnglish ? "/en/apply" : "/ja/apply";
const contactUrl = isEnglish ? "/en/contact" : "/ja/contact";
---

<div id="hub-overlay" class="hub-overlay" hidden></div>

<aside
  id="connect-hub"
  class="hub"
  aria-hidden="true"
  aria-labelledby="hub-title"
  data-lang={lang}
  data-greeting={t.greeting}
  data-thinking={t.thinking}
  data-you={t.you}
  data-guide={t.guide}
  data-fallback={t.fallback}
  data-connection-error={t.connectionError}
>
  <div class="hub__shell">
    <header class="hub__header">
      <div class="hub__heading">
      <h2 id="hub-title" class="hub__title">{t.title}</h2>
      <p class="hub__subtitle">{t.subtitle}</p>
    </div>

      <button
        id="close-hub"
        type="button"
        class="hub__close"
        aria-label={t.close}
      >
        {t.close}
      </button>
    </header>

    <div id="hub-thread" class="hub__thread" aria-live="polite"></div>

    <div class="hub__footer">
      <div class="hub__prompts" id="hub-prompts">
        <button type="button" class="hub-chip">{t.prompt1}</button>
        <button type="button" class="hub-chip">{t.prompt2}</button>
        <button type="button" class="hub-chip">{t.prompt3}</button>
        <button type="button" class="hub-chip">{t.prompt4}</button>
      </div>

      <div class="hub__utilities">
        <a href={applyUrl} class="hub__utility">{t.apply}</a>
        <a href={contactUrl} class="hub__utility">{t.contact}</a>
        <a
          href={handbookUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="hub__utility"
        >
          {t.handbook}
        </a>
      </div>

      <div class="hub__composer">
        <label class="sr-only" for="hub-input">{t.placeholder}</label>
        <input
          id="hub-input"
          type="text"
          class="hub__input"
          placeholder={t.placeholder}
        />
        <button id="hub-send" type="button" class="hub__send">
          {t.send}
        </button>
      </div>
    </div>
  </div>
</aside>

<button
  type="button"
  class="hub-fab open-hub-trigger"
  aria-label={isEnglish ? "Ask AI" : "AIに相談"}
>
  {isEnglish ? "Ask AI" : "AIに相談"}
</button>

<style is:global>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .hub-overlay {
    position: fixed;
    inset: 0;
    background: rgba(17, 19, 22, 0.56);
    backdrop-filter: blur(6px);
    z-index: 90;
    opacity: 0;
    transition: opacity 0.22s ease;
  }

  .hub-overlay.is-open {
    opacity: 1;
  }

  .hub {
    position: fixed;
    inset: 0 0 0 auto;
    width: min(100%, 28rem);
    z-index: 100;
    transform: translateX(100%);
    transition: transform 0.24s ease;
  }

  .hub.is-open {
    transform: translateX(0);
  }

  .hub__shell {
    height: 100dvh;
    display: grid;
    grid-template-rows: auto minmax(0, 1fr) auto;
    background: #171a1f;
    color: var(--color-text-inverse);
    border-left: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: -12px 0 40px rgba(0, 0, 0, 0.22);
  }

  .hub__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.95rem 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background: #171a1f;
  }

  .hub__title {
    margin: 0;
    font-size: 1rem;
    line-height: 1.2;
    font-weight: 700;
    color: var(--color-text-inverse);
    font-family: var(--font-body);
  }

  .hub__heading {
    display: grid;
    gap: 0.18rem;
    min-width: 0;
  }

  .hub__subtitle {
    margin: 0;
    font-size: 0.72rem;
    line-height: 1.2;
    color: rgba(245, 241, 232, 0.56);
    font-family: var(--font-body);
  }

  .hub__close {
    appearance: none;
    border: 0;
    background: transparent;
    color: rgba(245, 241, 232, 0.72);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    padding: 0.25rem 0;
    flex: 0 0 auto;
  }

  .hub__close:hover,
  .hub__close:focus-visible {
    color: var(--color-text-inverse);
  }

  .hub__thread {
    min-height: 0;
    overflow-y: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    -webkit-overflow-scrolling: touch;
  }

  .hub__thread::-webkit-scrollbar {
    width: 6px;
  }

  .hub__thread::-webkit-scrollbar-thumb {
    background: rgba(107, 124, 98, 0.32);
    border-radius: 999px;
  }

  .hub__message {
    display: flex;
    flex-direction: column;
    width: 100%;
    gap: 0.3rem;
  }

  .hub__message--assistant {
    align-items: flex-start;
  }

  .hub__message--user {
    align-items: flex-end;
  }

  .hub__meta {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(245, 241, 232, 0.56);
    font-family: var(--font-body);
  }

  .hub__message--assistant .hub__meta {
    color: var(--color-accent-soft);
  }

  .hub__bubble {
    display: inline-block;
    width: fit-content;
    max-width: 88%;
    padding: 0.85rem 0.95rem;
    border-radius: 1rem;
    line-height: 1.6;
    font-size: 0.94rem;
    white-space: normal;
    overflow-wrap: anywhere;
    word-break: break-word;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.12);
    font-family: var(--font-body);
  }

  .hub__bubble--assistant {
    background: #232830;
    color: var(--color-text-inverse);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-top-left-radius: 0.35rem;
    align-self: flex-start;
  }

  .hub__bubble--user {
    background: rgba(107, 124, 98, 0.22);
    color: var(--color-text-inverse);
    border: 1px solid rgba(135, 150, 125, 0.34);
    border-top-right-radius: 0.35rem;
    align-self: flex-end;
  }

  .hub__bubble--thinking {
    color: rgba(245, 241, 232, 0.72);
    font-style: italic;
  }

  .hub__bubble p,
  .hub__bubble ul,
  .hub__bubble ol,
  .hub__bubble h1,
  .hub__bubble h2,
  .hub__bubble h3,
  .hub__bubble h4,
  .hub__bubble h5,
  .hub__bubble h6,
  .hub__bubble div {
    margin-top: 0;
    margin-bottom: 0.7rem;
    max-width: 100%;
    color: inherit;
  }

  .hub__bubble p:last-child,
  .hub__bubble ul:last-child,
  .hub__bubble ol:last-child,
  .hub__bubble h1:last-child,
  .hub__bubble h2:last-child,
  .hub__bubble h3:last-child,
  .hub__bubble h4:last-child,
  .hub__bubble h5:last-child,
  .hub__bubble h6:last-child,
  .hub__bubble div:last-child {
    margin-bottom: 0;
  }

  .hub__bubble a {
    color: var(--color-accent-soft);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .hub__bubble a:hover,
  .hub__bubble a:focus-visible {
    color: #a7b59d;
  }

  .hub__answer,
  .hub__answer p,
  .hub__answer div {
    max-width: 100%;
    overflow-wrap: anywhere;
    word-break: break-word;
    margin: 0;
  }

  .hub__answer > * + * {
    margin-top: 0.7rem;
  }

  .hub__answer strong {
    font-weight: 700;
    color: #ffffff;
  }

  .hub__bullet {
    display: flex;
    gap: 0.5rem;
  }

  .hub__bullet-dot {
    color: var(--color-accent-soft);
    flex: 0 0 auto;
  }

  .hub__footer {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    background: #171a1f;
    padding: 0.85rem 0.85rem calc(0.85rem + env(safe-area-inset-bottom));
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .hub__prompts {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .hub-chip {
    appearance: none;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.035);
    color: rgba(245, 241, 232, 0.72);
    border-radius: 999px;
    padding: 0.5rem 0.72rem;
    font-size: 0.78rem;
    line-height: 1.2;
    cursor: pointer;
    transition: border-color 0.18s ease, color 0.18s ease, transform 0.18s ease, background 0.18s ease;
    font-family: var(--font-body);
  }

  .hub-chip:hover,
  .hub-chip:focus-visible {
    border-color: var(--color-accent);
    background: rgba(107, 124, 98, 0.12);
    color: var(--color-text-inverse);
    transform: translateY(-1px);
  }

  .hub__utilities {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .hub__utility {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2rem;
    padding: 0.48rem 0.78rem;
    border-radius: 999px;
    border: 1px solid rgba(135, 150, 125, 0.34);
    background: rgba(107, 124, 98, 0.16);
    color: var(--color-text-inverse);
    font-size: 0.76rem;
    font-weight: 700;
    line-height: 1;
    transition: border-color 0.18s ease, background 0.18s ease, transform 0.18s ease;
    font-family: var(--font-body);
  }

  .hub__utility:hover,
  .hub__utility:focus-visible {
    border-color: rgba(135, 150, 125, 0.55);
    background: rgba(107, 124, 98, 0.24);
    color: #ffffff;
    transform: translateY(-1px);
  }

  .hub__composer {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.55rem;
    align-items: center;
  }

  .hub__input {
    width: 100%;
    min-width: 0;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.04);
    color: var(--color-text-inverse);
    border-radius: 999px;
    padding: 0.82rem 0.95rem;
    font-size: 0.94rem;
    outline: none;
    font-family: var(--font-body);
  }

  .hub__input::placeholder {
    color: rgba(245, 241, 232, 0.5);
  }

  .hub__input:focus-visible {
    border-color: var(--color-accent);
  }

  .hub__send {
    appearance: none;
    border: 0;
    border-radius: 999px;
    background: var(--color-accent);
    color: #111111;
    font-size: 0.8rem;
    font-weight: 700;
    padding: 0.82rem 1rem;
    cursor: pointer;
    transition: background 0.18s ease, transform 0.18s ease;
    white-space: nowrap;
    font-family: var(--font-body);
  }

  .hub__send:hover,
  .hub__send:focus-visible {
    background: var(--color-accent-soft);
    transform: translateY(-1px);
  }

  .hub-fab {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 80;
    appearance: none;
    border: 1px solid rgba(214, 206, 194, 0.9);
    background: rgba(246, 241, 232, 0.94);
    color: #2b2620;
    border-radius: 999px;
    padding: 0.82rem 1rem;
    font-size: 0.82rem;
    font-weight: 700;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
    cursor: pointer;
    transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease;
    font-family: var(--font-body);
  }

  .hub-fab:hover,
  .hub-fab:focus-visible {
    transform: translateY(-1px);
    border-color: var(--color-accent);
    background: #f3f7f0;
  }

  .hub a:focus-visible,
  .hub button:focus-visible,
  .hub input:focus-visible,
  .hub-fab:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  @media (max-width: 767px) {
    .hub {
      width: 100%;
    }

    .hub__header {
      padding: 0.9rem 0.85rem;
    }

    .hub__thread {
      padding: 0.85rem;
    }

    .hub__footer {
      padding: 0.75rem 0.75rem calc(0.75rem + env(safe-area-inset-bottom));
    }

    .hub__bubble {
      max-width: 92%;
      font-size: 0.93rem;
    }

    .hub__send {
      padding-inline: 0.9rem;
    }

    .hub-fab {
      right: 0.75rem;
      bottom: 0.75rem;
    }
  }
</style>

<script>
  type ChatHistoryItem = { role: string; content: string };
  type AskResponse = {
    answer?: string;
  };

  const hub = document.getElementById("connect-hub");
  const overlay = document.getElementById("hub-overlay");
  const closeBtn = document.getElementById("close-hub");
  const thread = document.getElementById("hub-thread");
  const input = document.getElementById("hub-input") as HTMLInputElement | null;
  const sendBtn = document.getElementById("hub-send");
  const promptButtons = Array.from(document.querySelectorAll(".hub-chip"));

  let chatHistory: ChatHistoryItem[] = [];

  function escapeHtml(str: string): string {
    return String(str)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  function getHubText(name: string, fallback: string): string {
    if (!hub) return fallback;
    return hub.getAttribute(name) || fallback;
  }

  function scrollThreadToBottom(): void {
    if (!thread) return;
    requestAnimationFrame(() => {
      thread.scrollTop = thread.scrollHeight;
    });
  }

  function renderInitialMessage(): void {
    if (!thread || !input) return;

    chatHistory = [];
    input.value = "";

    const greeting = getHubText("data-greeting", "");
    const guideLabel = getHubText("data-guide", "Guide");

    thread.innerHTML = `
      <div class="hub__message hub__message--assistant">
        <div class="hub__meta">${escapeHtml(guideLabel)}</div>
        <div class="hub__bubble hub__bubble--assistant">
          ${escapeHtml(greeting)}
        </div>
      </div>
    `;

    scrollThreadToBottom();
  }

  function openHub(): void {
    if (!hub || !overlay) return;
    hub.classList.add("is-open");
    hub.setAttribute("aria-hidden", "false");
    overlay.hidden = false;

    requestAnimationFrame(() => {
      overlay.classList.add("is-open");
    });

    document.body.style.overflow = "hidden";

    setTimeout(() => {
      input?.focus();
      scrollThreadToBottom();
    }, 120);
  }

  function closeHub(): void {
    if (!hub || !overlay) return;

    hub.classList.remove("is-open");
    hub.setAttribute("aria-hidden", "true");
    overlay.classList.remove("is-open");

    setTimeout(() => {
      overlay.hidden = true;
      document.body.style.overflow = "";
      renderInitialMessage();
    }, 220);
  }

  function renderApprovedMarkdown(answer: string): string {
    const escaped = escapeHtml(answer);

    const rendered = escaped
      .replace(/\*\*(.*?)\*\*/g, "<strong>$1</strong>")
      .replace(
        /^\s*[\-\*]\s+(.*)/gm,
        '<div class="hub__bullet"><span class="hub__bullet-dot">•</span><span>$1</span></div>'
      )
      .replace(
        /\[(.*?)\]\((https:\/\/ywamsendai\.org\/[^)\s]+)\)/g,
        '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>'
      )
      .replace(/\n\n/g, "</p><p>")
      .replace(/\n/g, "<br>");

    return `<div class="hub__answer"><p>${rendered}</p></div>`;
  }

  function appendUserMessage(query: string): void {
    if (!thread) return;

    const youLabel = getHubText("data-you", "You");

    const wrapper = document.createElement("div");
    wrapper.className = "hub__message hub__message--user";

    const meta = document.createElement("div");
    meta.className = "hub__meta";
    meta.textContent = youLabel;

    const bubble = document.createElement("div");
    bubble.className = "hub__bubble hub__bubble--user";
    bubble.textContent = query;

    wrapper.appendChild(meta);
    wrapper.appendChild(bubble);
    thread.appendChild(wrapper);

    scrollThreadToBottom();
  }

  function appendThinkingMessage(): HTMLElement | null {
    if (!thread) return null;

    const guideLabel = getHubText("data-guide", "Guide");
    const thinking = getHubText("data-thinking", "Thinking...");

    const wrapper = document.createElement("div");
    wrapper.className = "hub__message hub__message--assistant";

    const meta = document.createElement("div");
    meta.className = "hub__meta";
    meta.textContent = guideLabel;

    const bubble = document.createElement("div");
    bubble.className = "hub__bubble hub__bubble--assistant hub__bubble--thinking";
    bubble.textContent = thinking;

    wrapper.appendChild(meta);
    wrapper.appendChild(bubble);
    thread.appendChild(wrapper);

    scrollThreadToBottom();
    return bubble;
  }

  async function sendMessage(prefill?: string): Promise<void> {
    if (!input || !thread) return;

    const query = (prefill ?? input.value).trim();
    if (!query) return;

    appendUserMessage(query);
    input.value = "";

    const botBubble = appendThinkingMessage();
    if (!botBubble) return;

    try {
      const currentLang = getHubText("data-lang", document.documentElement.lang || "en");

      const response = await fetch("https://api.ywamsendai.org/ask", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          question: query,
          lang: currentLang,
          history: chatHistory
        })
      });

      if (!response.ok) throw new Error("API unreachable");

      const data = (await response.json()) as AskResponse;

      if (data.answer) {
        chatHistory.push({ role: "user", content: query });
        chatHistory.push({ role: "assistant", content: data.answer });

        if (chatHistory.length > 12) {
          chatHistory = chatHistory.slice(-12);
        }

        const formatted = renderApprovedMarkdown(data.answer);

        botBubble.classList.remove("hub__bubble--thinking");
        botBubble.innerHTML = formatted;
      } else {
        botBubble.classList.remove("hub__bubble--thinking");
        botBubble.textContent = getHubText(
          "data-fallback",
          currentLang === "ja"
            ? "申し訳ありません。データ内で答えが見つかりませんでした。"
            : "I'm sorry, I couldn't find an answer in the data."
        );
      }
    } catch (_error) {
      const currentLang = getHubText("data-lang", document.documentElement.lang || "en");

      botBubble.classList.remove("hub__bubble--thinking");
      botBubble.textContent = getHubText(
        "data-connection-error",
        currentLang === "ja" ? "接続エラーが発生しました。" : "Connection error."
      );
    }

    scrollThreadToBottom();
  }

  if (sendBtn) {
    sendBtn.addEventListener("click", () => {
      void sendMessage();
    });
  }

  if (input) {
    input.addEventListener("keypress", (e: KeyboardEvent) => {
      if (e.key === "Enter") {
        e.preventDefault();
        void sendMessage();
      }
    });
  }

  promptButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const text = button.textContent?.trim() || "";
      if (text) void sendMessage(text);
    });
  });

  document.addEventListener("click", (e: MouseEvent) => {
    const target = e.target;
    if (!(target instanceof HTMLElement)) return;

    const trigger = target.closest(".open-hub-trigger");
    if (!trigger) return;

    e.preventDefault();
    openHub();
  });

  if (closeBtn) {
    closeBtn.addEventListener("click", closeHub);
  }

  if (overlay) {
    overlay.addEventListener("click", closeHub);
  }

  document.addEventListener("keydown", (e: KeyboardEvent) => {
    if (e.key === "Escape") {
      closeHub();
    }
  });

  renderInitialMessage();
</script>