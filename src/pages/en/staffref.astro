---
import Layout from "../../layouts/Layout.astro";
---

<Layout
  lang="en"
  title="Staff Character Reference | YWAM Sendai"
  description="Provide a character reference for someone applying to join YWAM Sendai staff."
>
  <section class="section bg-paper">
    <div class="container container-narrow">
      <div class="stack center" style="text-align: center;">
        <div>
          <p class="eyebrow">Reference Form</p>
          <h1 class="section-title">Staff Character Reference</h1>
        </div>

        <p class="lead mx-auto">
          This form is for people who have been asked to provide a character reference
          for someone applying to join YWAM Sendai staff.
        </p>

        <p class="text-soft">
          You may have received this form as a pastor, DTS leader, friend, or another person
          who knows the applicant well. Thank you for taking the time to help with this process.
        </p>
      </div>

      <div class="card" style="padding: 0; overflow: hidden; margin-top: 2rem;">
        <div
          style="width:100%;min-height:640px;"
          data-fillout-id="jWvtZ53xMRus"
          data-fillout-embed-type="standard"
          data-fillout-inherit-parameters
          data-fillout-dynamic-resize
        ></div>
      </div>

      <div class="center" style="margin-top: 1.5rem; text-align: center;">
        <p class="text-soft">
          If you have questions about this form, please contact YWAM Sendai directly.
        </p>
        <a href="/en/contact" class="btn-text">Contact YWAM Sendai</a>
      </div>
    </div>
  </section>

  <script src="https://server.fillout.com/embed/v1/" defer></script>
</Layout>