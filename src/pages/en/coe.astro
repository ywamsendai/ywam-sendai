---
import Layout from "../../layouts/Layout.astro";
---

<Layout
  lang="en"
  title="Certificate of Eligibility (CoE) Information Form | YWAM Sendai"
  description="Submit information needed for a Certificate of Eligibility application related to a Religious Worker visa."
>
  <section class="section bg-paper">
    <div class="container container-narrow">
      <div class="stack center" style="text-align: center;">
        <div>
          <p class="eyebrow">Visa Information Form</p>
          <h1 class="section-title">Certificate of Eligibility (CoE) Information Form</h1>
        </div>

        <p class="lead mx-auto">
          This form is used to collect the information needed for a Certificate of Eligibility
          application related to a Religious Worker visa.
        </p>

        <p class="text-soft">
          Please complete this form carefully and provide accurate information.
          This will help YWAM Sendai prepare the necessary documents for the application process.
        </p>
      </div>

      <div class="card" style="padding: 0; overflow: hidden; margin-top: 2rem;">
        <div
          style="width:100%;min-height:640px;"
          data-fillout-id="pqMYHzQHUBus"
          data-fillout-embed-type="standard"
          data-fillout-inherit-parameters
          data-fillout-dynamic-resize
        ></div>
      </div>

      <div class="center" style="margin-top: 1.5rem; text-align: center;">
        <p class="text-soft">
          If you have questions about this form or the visa process, please contact YWAM Sendai directly.
        </p>
        <a href="/en/contact" class="btn-text">Contact YWAM Sendai</a>
      </div>
    </div>
  </section>

  <script src="https://server.fillout.com/embed/v1/" defer></script>
</Layout>