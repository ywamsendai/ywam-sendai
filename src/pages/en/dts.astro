---
import Layout from '../../layouts/Layout.astro';

export const metadata = {
  school: "Discipleship Training School",
  location: "Sendai, Japan",
  method: "Live Learn Environment",
  curriculum: "Bible, God, Salvation, Mission, Identity",
};
---

<Layout title="Discipleship Training School | YWAM Sendai">
  <main class="bg-dark-bg min-h-screen text-zinc-300 pb-20">
    
    <div class="h-[40vh] relative flex items-center justify-center overflow-hidden">
      <img src="/hero-sendai.jpg" class="absolute inset-0 w-full h-full object-cover opacity-20" />
      <div class="relative z-10 text-center">
        <a href="/en" class="text-[10px] tracking-[0.4em] text-gold-accent hover:opacity-70 transition-opacity uppercase mb-4 block">← Back to Vision</a>
        <h1 class="text-5xl md:text-7xl font-serif text-white">DTS</h1>
        <p class="tracking-[.2em] uppercase text-xs mt-2">Discipleship Training School</p>
      </div>
    </div>

    <div class="max-w-4xl mx-auto px-6 mt-12 space-y-20">
      
      <section class="prose prose-invert max-w-none">
        <h2 class="text-3xl font-serif text-white italic">To Know God and Make Him Known.</h2>
        <p class="text-lg leading-relaxed text-zinc-400">
          The DTS is more than a course; it is a five-month journey of spiritual formation designed to help you encounter the presence of God and discover your place in His global mission. In Sendai, we focus on <span class="text-gold-accent italic">Theosis</span>—the process of being transformed into the likeness of Christ through intimacy and obedience.
        </p>
      </section>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-zinc-900/50 border border-zinc-800 p-8 rounded-3xl">
          <h3 class="text-gold-accent font-bold uppercase tracking-widest text-sm mb-4">Lecture Phase</h3>
          <p class="text-sm leading-relaxed">12 weeks of immersive teaching. Topics include the Nature and Character of God, Hearing God's Voice, Biblical Worldview, and Spiritual Warfare. Set in the quiet, focused environment of our Sendai community.</p>
        </div>
        <div class="bg-zinc-900/50 border border-zinc-800 p-8 rounded-3xl">
          <h3 class="text-gold-accent font-bold uppercase tracking-widest text-sm mb-4">Outreach Phase</h3>
          <p class="text-sm leading-relaxed">8-12 weeks of cross-cultural mission. Take what you have learned and apply it in the field, serving local churches and communities in Japan and beyond.</p>
        </div>
      </div>

      <section class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-zinc-900/20 border border-zinc-800 p-6 rounded-2xl text-center">
          <span class="block text-[10px] uppercase text-zinc-500 mb-2">Next Date</span>
          <span class="text-zinc-200 font-bold">Sept 2026</span>
        </div>
        <div class="bg-zinc-900/20 border border-zinc-800 p-6 rounded-2xl text-center">
          <span class="block text-[10px] uppercase text-zinc-500 mb-2">Location</span>
          <span class="text-zinc-200 font-bold">Sendai, Japan</span>
        </div>
        <div class="bg-zinc-900/20 border border-zinc-800 p-6 rounded-2xl text-center">
          <span class="block text-[10px] uppercase text-zinc-500 mb-2">Tuition</span>
          <span class="text-zinc-200 font-bold">¥XXX,XXX</span>
        </div>
      </section>

      <div class="text-center py-10 border-t border-zinc-800">
        <h3 class="text-2xl font-serif mb-6">Ready to take the step?</h3>
        <a href="/en/apply" class="inline-block px-12 py-4 bg-gold-accent text-black font-black rounded-full uppercase tracking-widest text-xs hover:scale-105 transition-transform">
          Start Application
        </a>
      </div>

    </div>
  </main>
</Layout>