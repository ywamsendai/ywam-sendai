---
const { lang = 'en' } = Astro.props;

const content = {
  en: {
    title: "Let's Connect.",
    subtitle: "Choose the path that fits your journey.",
    path0Tag: "Ready to Join?",
    path0Title: "Start Application",
    path0Desc: "For students, staff, visitors, and teams ready to begin their journey in Sendai.",
    path1Tag: "Instant Knowledge",
    path1Title: "Talk with our AI Guide (Beta)",
    path1Desc: "Ask about who we are, costs, or dates. Our handbook is at your fingertips.",
    path2Tag: "Relational Step",
    path2Title: "Message on Instagram",
    path2Desc: "Send us a DM. We'd love to hear your story personally.",
    path3Tag: "Self-Guided",
    path3Title: "Browse the Handbook",
    path3Desc: "Read the full documentation at your own pace.",
    emailLabel: "Or send us an Email",
    close: "Close ✕",
    back: "← Back to Options",
    chatGreeting: "Greetings. I am the YWAM Sendai Guide (Beta). How can I assist you?",
    chatPlaceholder: "Ask about costs, dates...",
    send: "Send"
  },
  ja: {
    title: "つながる。",
    subtitle: "あなたに合った方法で、一歩を踏み出してください。",
    path0Tag: "準備はできましたか？",
    path0Title: "出願・参加申し込み",
    path0Desc: "生徒、スタッフ、個人訪問者、チームとして参加を希望される方はこちらから。",
    path1Tag: "即座に回答",
    path1Title: "AIガイドに質問する（ベータ）",
    path1Desc: "ビジョン、費用、日程について。ハンドブックがあなたをサポートします。",
    path2Tag: "関係を築く",
    path2Title: "公式LINEで相談する",
    path2Desc: "メッセージをお送りください。個別にお返事させていただきます。",
    path3Tag: "自分で探す",
    path3Title: "ハンドブックを読む",
    path3Desc: "仙台ガイドの全ドキュメントを、自分のペースで確認できます。",
    emailLabel: "またはメールで問い合わせる",
    close: "閉じる ✕",
    back: "← 戻る",
    chatGreeting: "こんにちは。仙台ガイドです（ベータ）。あなたの質問にお答えします。",
    chatPlaceholder: "費用や日程について聞く...",
    send: "送信"
  }
};

const t = lang === 'ja' ? content.ja : content.en;
---

<div id="hub-overlay" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-[90] hidden opacity-0 transition-opacity duration-500"></div>

<div id="connect-hub" class="fixed inset-y-0 right-0 w-full md:w-[450px] bg-zinc-950 border-l border-zinc-900 z-[100] translate-x-full transition-transform duration-500 ease-in-out p-10 flex flex-col font-sans">
  
  <button id="close-hub" class="absolute top-6 right-6 text-zinc-500 hover:text-white uppercase text-[10px] tracking-widest">{t.close}</button>

  <div id="hub-main-content" class="mt-12 flex-grow transition-opacity duration-300">
    <h2 class="font-serif text-3xl italic text-white mb-2">{t.title}</h2>
    <p class="text-xs text-zinc-500 mb-12">{t.subtitle}</p>
    
    <div class="space-y-4">
      <a 
        href="https://ywamsendai.org/apply" 
        class="group block p-6 bg-gold-accent text-black rounded-3xl hover:scale-[1.02] transition-all mb-8 shadow-lg shadow-gold-accent/10"
      >
        <span class="text-black/60 text-[9px] uppercase tracking-[0.3em] font-black block mb-1">{t.path0Tag}</span>
        <h3 class="text-lg font-black uppercase tracking-tight">{t.path0Title}</h3>
        <p class="text-[11px] text-black/70 mt-1 leading-relaxed font-medium">{t.path0Desc}</p>
      </a>

      <button id="start-chat" class="w-full text-left group p-6 bg-zinc-900/50 border border-zinc-800 rounded-3xl hover:border-gold-accent/50 transition-all cursor-pointer">
        <span class="text-gold-accent text-[9px] uppercase tracking-[0.3em] block mb-1">{t.path1Tag}</span>
        <h3 class="text-lg font-bold text-zinc-200">{t.path1Title}</h3>
        <p class="text-[11px] text-zinc-500 mt-2 leading-relaxed">{t.path1Desc}</p>
      </button>

      <a 
        href={lang === 'ja' ? "https://lin.ee/LD2Nf4b" : "https://ig.me/m/ywamsendai"} 
        target="_blank" 
        rel="noopener noreferrer"
        class="group block p-6 bg-zinc-900/30 border border-zinc-800/50 rounded-3xl hover:border-zinc-600 transition-all"
      >
        <span class="text-zinc-500 text-[9px] uppercase tracking-[0.3em] block mb-1">{t.path2Tag}</span>
        <h3 class="text-lg font-bold text-white">{t.path2Title}</h3>
        <p class="text-[11px] text-zinc-500 mt-2 leading-relaxed">{t.path2Desc}</p>
      </a>

      <a 
        href={lang === 'ja' ? "https://guide.ywamsendai.org/ja" : "https://guide.ywamsendai.org/en"} 
        target="_blank" 
        rel="noopener noreferrer"
        class="group block p-6 bg-zinc-900/30 border border-zinc-800/50 rounded-3xl hover:border-zinc-600 transition-all"
      >
        <span class="text-zinc-500 text-[9px] uppercase tracking-[0.3em] block mb-1">{t.path3Tag}</span>
        <h3 class="text-lg font-bold text-white">{t.path3Title}</h3>
        <p class="text-[11px] text-zinc-500 mt-2 leading-relaxed">{t.path3Desc}</p>
      </a>

      <div class="pt-4 text-center">
        <a href="mailto:hello@ywamsendai.org" class="text-[10px] text-zinc-600 hover:text-gold-accent transition-colors uppercase tracking-[0.2em] font-bold">
          {t.emailLabel}
        </a>
      </div>
    </div>
  </div>

  <div id="hub-chat-ui" class="mt-12 flex-grow hidden opacity-0 transition-opacity duration-300 flex flex-col overflow-hidden">
    <button id="back-to-hub" class="text-[9px] text-zinc-500 uppercase tracking-widest mb-6 hover:text-gold-accent text-left">{t.back}</button>
    <div id="chat-messages" class="flex-grow overflow-y-auto text-[13px] space-y-4 pr-2 scrollbar-hide">
       <div class="text-gold-accent font-serif italic mb-6">{t.chatGreeting}</div>
    </div>
    <div class="mt-4 flex border-t border-zinc-900 pt-6">
      <input id="chat-input" type="text" placeholder={t.chatPlaceholder} class="bg-transparent w-full outline-none text-white text-sm placeholder:text-zinc-700">
      <button id="send-chat" class="text-gold-accent text-[10px] font-bold uppercase tracking-widest ml-2">{t.send}</button>
    </div>
  </div>

  <div id="hub-footer" class="mt-auto pt-10 border-t border-zinc-900">
    <p class="text-[10px] text-zinc-700 leading-relaxed italic">
      {lang === 'ja' 
        ? "「私たちは、あなたが神様から受けている召しを共に分かち合えることを楽しみにしています。」" 
        : "Every connection is an invitation to participate in the life of God together."}
    </p>
  </div>
</div>

<style>
  #chat-messages::-webkit-scrollbar { width: 2px; }
  #chat-messages::-webkit-scrollbar-track { background: transparent; }
  #chat-messages::-webkit-scrollbar-thumb { background: #c5a05933; }
</style>

<script>
  // [SCRIPTS REMAIN UNCHANGED - ONLY SELECTORS UPDATED]
  const hub = document.getElementById('connect-hub')!;
  const overlay = document.getElementById('hub-overlay')!;
  const closeBtn = document.getElementById('close-hub')!;
  const mainContent = document.getElementById('hub-main-content')!;
  const chatUI = document.getElementById('hub-chat-ui')!;
  const startChatBtn = document.getElementById('start-chat')!;
  const backBtn = document.getElementById('back-to-hub')!;
  const hubFooter = document.getElementById('hub-footer')!;
  const chatMessages = document.getElementById('chat-messages')!;
  const chatInput = document.getElementById('chat-input') as HTMLInputElement;
  const sendBtn = document.getElementById('send-chat')!;

  function openHub() {
    hub.classList.remove('translate-x-full');
    overlay.classList.remove('hidden');
    setTimeout(() => overlay.classList.add('opacity-100'), 10);
    document.body.style.overflow = 'hidden'; 
  }

  function closeHub() {
    hub.classList.add('translate-x-full');
    overlay.classList.remove('opacity-100');
    setTimeout(() => {
      overlay.classList.add('hidden');
      document.body.style.overflow = ''; 
      resetToMenu();
    }, 500);
  }

  function resetToMenu() {
    chatUI.classList.add('hidden', 'opacity-0');
    mainContent.classList.remove('hidden', 'opacity-0');
    hubFooter.classList.remove('hidden');
  }

  startChatBtn.addEventListener('click', () => {
    mainContent.classList.add('opacity-0');
    setTimeout(() => {
      mainContent.classList.add('hidden');
      hubFooter.classList.add('hidden');
      chatUI.classList.remove('hidden');
      setTimeout(() => chatUI.classList.add('opacity-100'), 10);
    }, 300);
  });

  backBtn.addEventListener('click', () => {
    chatUI.classList.remove('opacity-100');
    setTimeout(() => {
      chatUI.classList.add('hidden');
      mainContent.classList.remove('hidden');
      hubFooter.classList.remove('hidden');
      setTimeout(() => mainContent.classList.remove('opacity-0'), 10);
    }, 300);
  });

  // [SEND MESSAGE LOGIC UNCHANGED]
  async function sendMessage() {
    const query = chatInput.value.trim();
    if (!query) return;
    chatMessages.innerHTML += `<div class="text-right mt-6"><div class="text-[9px] text-zinc-600 uppercase tracking-widest mb-2">You</div><div class="text-zinc-200 leading-relaxed inline-block bg-zinc-900/50 px-4 py-2 rounded-2xl rounded-tr-none">${query}</div></div>`;
    chatInput.value = '';
    chatMessages.scrollTop = chatMessages.scrollHeight;
    const botId = `bot-${Date.now()}`;
    chatMessages.innerHTML += `<div class="text-left mt-6"><div class="text-[9px] text-gold-accent uppercase tracking-widest mb-2">Guide</div><div id="${botId}" class="text-zinc-400 italic bg-gold-accent/5 px-4 py-2 rounded-2xl rounded-tl-none">Thinking...</div></div>`;
    chatMessages.scrollTop = chatMessages.scrollHeight;
    try {
      const currentLang = document.documentElement.lang || 'en';
      const response = await fetch('https://ywam-guide-api.ywamsendai.workers.dev/ask', { 
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ question: query, lang: currentLang })
      });
      if (!response.ok) throw new Error('API unreachable');
      const data = await response.json();
      const botEl = document.getElementById(botId)!;
      botEl.classList.remove('italic', 'text-zinc-400');
      botEl.classList.add('text-zinc-300');
      if (data.answer) {
        const formatted = data.answer
          .replace(/\*\*(.*?)\*\*/g, '<strong class="text-white font-bold">$1</strong>')
          .replace(/^\s*[\-\*]\s+(.*)/gm, '<div class="flex gap-2"><span class="text-gold-accent">•</span><span>$1</span></div>')
          .replace(/\[(.*?)\]\((.*?)\)/g, '<a href="$2" target="_blank" class="text-gold-accent underline hover:text-white transition-colors">$1</a>')
          .replace(/\n\n/g, '</div><div class="mt-3">')
          .replace(/\n/g, '<br>');
        botEl.innerHTML = `<div class="leading-relaxed">${formatted}</div>`;
      } else {
        botEl.innerText = currentLang === 'ja' ? "申し訳ありません。答えが見つかりませんでした。" : "I'm sorry, I couldn't find an answer in the guide.";
      }
    } catch (e) {
      const currentLang = document.documentElement.lang || 'en';
      document.getElementById(botId)!.innerText = currentLang === 'ja' ? "接続エラーが発生しました。" : "Connection error.";
    }
    chatMessages.scrollTop = chatMessages.scrollHeight;
  }

  sendBtn.addEventListener('click', sendMessage);
  chatInput.addEventListener('keypress', (e) => { if(e.key === 'Enter') sendMessage(); });
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.closest('.open-hub-trigger')) openHub();
  });
  closeBtn.addEventListener('click', closeHub);
  overlay.addEventListener('click', closeHub);
</script>